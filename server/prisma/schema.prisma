// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              Int              @id @default(autoincrement())
  name            String
  email           String           @unique
  password        String
  role            String           // ADMIN, TEAM_LEAD, SALES
  tenantId        Int
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  teamId          Int?
  team            Team?            @relation(fields: [teamId], references: [id])
  leads           Lead[]
  interactions    Interaction[]
  employeeProfile EmployeeProfile?
  managedTeam     Team?            @relation("TeamLead")
  pushSubscriptions PushSubscription[]
  suggestions     Suggestion[]
  answeredSuggestions Suggestion[]  @relation("SuggestionAnsweredBy")
  releaseNoteReads ReleaseNoteRead[]
  createdReleaseNotes ReleaseNote[] @relation("ReleaseNoteCreatedBy")
  createdFaqs      FAQ[]            @relation("FaqCreatedBy")
  updatedFaqs      FAQ[]            @relation("FaqUpdatedBy")

  @@index([tenantId])
  @@index([teamId])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Lead {
  id           Int           @id @default(autoincrement())
  name         String
  phone        String
  whatsappPhone String?
  profileDetails String?
  gender       String        @default("UNKNOWN") // MALE, FEMALE, UNKNOWN
  hasProvidedName Boolean    @default(false)
  isHiddenFromSales Boolean  @default(false)
  isVip        Boolean       @default(false)
  claimedAt    DateTime?
  status       String        // NEW, INTERESTED, AGREED, REJECTED, HESITANT, SPONSOR, NO_ANSWER, RECONTACT
  source       String        // CALL, SEND, POOL
  notes        String?
  recontactAttempts Int      @default(0)
  nextRecontactAt DateTime?
  lastRecontactAt DateTime?
  batchId      Int?
  batch        LeadBatch?    @relation(fields: [batchId], references: [id])
  tenantId     Int
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  agentId      Int?
  agent        User?         @relation(fields: [agentId], references: [id])
  teamId       Int?
  team         Team?         @relation(fields: [teamId], references: [id])
  courseId     Int?
  course       Course?       @relation(fields: [courseId], references: [id])
  createdAt    DateTime      @default(now())
  interactions Interaction[]

  @@index([tenantId])
  @@index([teamId])
  @@index([status])
  @@index([nextRecontactAt])
  @@index([batchId])
  @@index([hasProvidedName])
  @@index([isHiddenFromSales])
}

model Course {
  id    Int    @id @default(autoincrement())
  name  String
  price Float
  leads Lead[]
}

model Interaction {
  id      Int      @id @default(autoincrement())
  leadId  Int
  lead    Lead     @relation(fields: [leadId], references: [id])
  userId  Int?
  user    User?    @relation(fields: [userId], references: [id])
  type    String   // CALL, SEND
  outcome String?
  notes   String?
  date    DateTime @default(now())
}

model LeadBatch {
  id        Int      @id @default(autoincrement())
  name      String
  location  String?
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  leads     Lead[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([location])
}

model MessageTemplate {
  id        Int    @id @default(autoincrement())
  status    String // AGREED, REJECTED, HESITANT, SPONSOR
  content   String
  tenantId  Int
  tenant    Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, status])
  @@index([tenantId])
}

model EmployeeProfile {
  id              Int      @id @default(autoincrement())
  userId           Int      @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  department       String   @default("Sales")
  jobTitle         String?
  phone            String?
  timezone         String   @default("Africa/Cairo")
  dailyCallTarget  Int      @default(30)
  dailyApprovalTarget Int   @default(0)
  dailyInterestedTarget Int @default(0)
  simSerialNumber  String?
  simPhoneNumber   String?
  manualVipLimit   Int?     // If null, use automatic logic based on approvals. If set, use this limit.
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Team {
  id          Int      @id @default(autoincrement())
  name        String
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  leadId      Int?     @unique
  lead        User?    @relation("TeamLead", fields: [leadId], references: [id], onDelete: SetNull)
  users       User[]
  leads       Lead[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Tenant {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  slug             String            @unique
  users            User[]
  teams            Team[]
  leads            Lead[]
  leadBatches      LeadBatch[]
  messageTemplates MessageTemplate[]
  suggestions      Suggestion[]
  faqs             FAQ[]
  releaseNotes     ReleaseNote[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Suggestion {
  id        Int      @id @default(autoincrement())
  content   String
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  answer    String?
  answeredAt DateTime?
  answeredById Int?
  answeredBy User?   @relation("SuggestionAnsweredBy", fields: [answeredById], references: [id], onDelete: SetNull)
  tenantId  Int
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([answeredById])
}

model FAQ {
  id          Int      @id @default(autoincrement())
  question    String
  answer      String
  category    String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdById Int?
  createdBy   User?    @relation("FaqCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById Int?
  updatedBy   User?    @relation("FaqUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, isPublished])
  @@index([tenantId, sortOrder])
}

model ReleaseNote {
  id          Int      @id @default(autoincrement())
  title       String
  body        String
  version     String?
  isPublished Boolean  @default(true)
  publishedAt DateTime @default(now())
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdById Int?
  createdBy   User?    @relation("ReleaseNoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  reads       ReleaseNoteRead[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, publishedAt])
  @@index([tenantId, isPublished])
}

model ReleaseNoteRead {
  id            Int         @id @default(autoincrement())
  releaseNoteId Int
  releaseNote   ReleaseNote @relation(fields: [releaseNoteId], references: [id], onDelete: Cascade)
  userId        Int
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt        DateTime    @default(now())

  @@unique([releaseNoteId, userId])
  @@index([userId, readAt])
}
